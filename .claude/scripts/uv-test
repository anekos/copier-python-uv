#!/usr/bin/env bash

set -euC
# set -o pipefail

INPUT=$(cat)

# 既に Stop hook が動いている場合はスキップ
if echo "$INPUT" | jq -e '.stop_hook_active == true' > /dev/null 2>&1
then
  exit 0
fi

set +e
uv run pytest
status=$?

# exit 5 = no tests collected (treat as success)
if [ "$status" -eq 5 ]
then
  exit 0
fi

exit "$status"
