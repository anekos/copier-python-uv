[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.13"
dependencies = []

[project.scripts]
{{ package_name }} = "{{ package_name }}.main:main"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[dependency-groups]
dev = []

[tool.mypy]
mypy_path = "src"
explicit_package_bases = true
